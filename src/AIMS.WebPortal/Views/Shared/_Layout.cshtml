<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] — AIMS</title>
    <link rel="icon" type="image/avif" href="~/img/deha-logo.avif?v=4" />
    <link rel="shortcut icon" type="image/avif" href="~/img/deha-logo.avif?v=4" />
    <link rel="apple-touch-icon" href="~/img/deha-logo.avif?v=4" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/shared-layout.css" />
    <link rel="stylesheet" href="~/css/view-utilities.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>

<body>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <nav id="sidebar">
            <div class="brand">
                <div class="brand-shell">
                    <img class="brand-logo"
                         src="~/img/deha-logo.avif"
                         alt="DEHA Digital Solutions" />
                </div>
                <div class="brand-text">
                    <span class="brand-title">AIMS</span>
                    <span class="brand-subtitle">Quản lý thực tập sinh</span>
                </div>
                <div class="brand-accent"></div>
            </div>
            <div class="sidebar-scroll">
                @await Html.PartialAsync("_Sidebar")
            </div>
        </nav>

        <div id="main">
            <div class="topbar">
                <span class="text-muted">@ViewData["Title"]</span>
                <div class="ms-auto d-flex align-items-center gap-3">
                    <span class="badge bg-primary rounded-pill">
                        @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                    </span>
                    <span class="text-dark fw-semibold">
                        @User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value
                    </span>
                    <a asp-controller="Account"
                    asp-action="Logout"
                    asp-area=""              @* ⭐ Bắt buộc phải có *@
                    class="btn btn-sm btn-outline-danger">
                        <i class="bi bi-box-arrow-right"></i> Đăng xuất
                    </a>
                </div>
            </div>
            <div class="page-body">
                @RenderBody()
            </div>
        </div>
    }
    else
    {
        @RenderBody()
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
