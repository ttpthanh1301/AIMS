@using System.Security.Claims
@using AIMS.ViewModels.TaskManagement
@using AIMS.WebPortal.Services
@inject BackendApiClient Api

@{
    var roles = User.Claims
        .Where(c => c.Type == ClaimTypes.Role)
        .Select(c => c.Value).ToList();
    bool isAdmin = roles.Contains("Admin");
    bool isHR = roles.Contains("HR");
    bool isMentor = roles.Contains("Mentor");
    bool isIntern = roles.Contains("Intern");
    var pendingReportCount = 0;

    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var area = ViewContext.RouteData.Values["area"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    if (isMentor)
    {
        var mentorReports = await Api.GetAsync<List<DailyReportVm>>("/api/dailyreports")
            ?? new List<DailyReportVm>();
        pendingReportCount = mentorReports.Count(r => !r.HasFeedback);
    }
}

<ul class="nav flex-column mt-3 pb-4">

    @* ── HR ─────────────────────────────────────── *@
    @if (isAdmin)
    {
        <div class="nav-section">Quản trị</div>
        <li class="nav-item">
            <a class="nav-link @(area == "Admin" && ctrl == "Dashboard" ? "active" : "")" asp-area="Admin"
                   asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-grid me-2"></i>Admin Dashboard
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(area == "Admin" && ctrl == "User" ? "active" : "")" asp-area="Admin"
                   asp-controller="User" asp-action="Index">
                <i class="bi bi-people me-2"></i>Người dùng
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(area == "Admin" && ctrl == "InternshipPeriod" ? "active" : "")" asp-area="Admin"
                   asp-controller="InternshipPeriod" asp-action="Index">
                <i class="bi bi-calendar-range me-2"></i>Kỳ thực tập
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(area == "Admin" && ctrl == "InternAssignment" ? "active" : "")" asp-area="Admin"
                   asp-controller="InternAssignment" asp-action="Index">
                <i class="bi bi-diagram-3 me-2"></i>Phân công intern
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(area == "Admin" && ctrl == "Role" ? "active" : "")" asp-area="Admin"
                   asp-controller="Role" asp-action="Index">
                <i class="bi bi-key me-2"></i>Roles
            </a>
        </li>
    }

    @if (isHR)
    {
        <div class="nav-section">Tuyển dụng</div>
        <li class="nav-item">
            <a class="nav-link @(area == "HR" && ctrl == "JobDescription" ? "active" : "")" asp-area="HR"
                   asp-controller="JobDescription" asp-action="Index">
                <i class="bi bi-file-text me-2"></i>Job Descriptions
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(area == "HR" && ctrl == "Screening" ? "active" : "")" asp-area="HR"
                   asp-controller="Screening" asp-action="Index">
                <i class="bi bi-robot me-2"></i>AI Screening
            </a>
        </li>
    }

    @* ── Mentor ──────────────────────────────────── *@
    @if (isMentor)
    {
        <div class="nav-section">Đào tạo</div>
        <li class="nav-item">
            <a class="nav-link @(area == "Mentor" && ctrl == "Course" ? "active" : "")" asp-area="Mentor"
                   asp-controller="Course"    asp-action="Index">
                <i class="bi bi-collection-play me-2"></i>Quản lý Khóa học
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(area == "Mentor" && ctrl == "Progress" ? "active" : "")" asp-area="Mentor"
                   asp-controller="Progress"    asp-action="Courses">
                <i class="bi bi-graph-up me-2"></i>Tiến độ Intern
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(area == "Mentor" && ctrl == "Quiz" ? "active" : "")" asp-area="Mentor"
                   asp-controller="Quiz"               asp-action="Index">
                <i class="bi bi-pencil-square me-2"></i>Quiz
            </a>
        </li>
        <div class="nav-section">Thực tập</div>
        <li class="nav-item">
            <a class="nav-link @(area == "Mentor" && ctrl == "Task" ? "active" : "")" asp-area="Mentor"
                   asp-controller="Task"         asp-action="Index">
                <i class="bi bi-kanban me-2"></i>Kanban Board
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(area == "Mentor" && ctrl == "Dashboard" && action == "DailyReports" ? "active" : "")"
                   asp-area="Mentor"              asp-controller="Dashboard" asp-action="DailyReports">
                <i class="bi bi-journal-text me-2"></i>Daily Reports
                @if (pendingReportCount > 0)
                {
                    <span class="badge bg-danger rounded-pill ms-auto">@pendingReportCount</span>
                }
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(area == "Mentor" && ctrl == "Dashboard" && action == "Timesheets" ? "active" : "")"
                   asp-area="Mentor"                 asp-controller="Dashboard" asp-action="Timesheets">
                <i class="bi bi-clock me-2"></i>Timesheet
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(area == "Mentor" && ctrl == "Dashboard" && action == "Index" ? "active" : "")"
                   asp-area="Mentor"                asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-bar-chart me-2"></i>Dashboard
            </a>
        </li>
    }

    @* ── Intern ──────────────────────────────────── *@
    @if (isIntern)
    {
        <div class="nav-section">Học tập</div>
        <li class="nav-item">
            <a class="nav-link @(area == "Intern" && ctrl == "LMS" ? "active" : "")" asp-area="Intern" asp-controller="LMS"
                   asp-action="Index">
                <i class="bi bi-play-circle me-2"></i>Khóa học của tôi
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(area == "Intern" && ctrl == "Quiz" ? "active" : "")" asp-area="Intern"
                   asp-controller="Quiz" asp-action="Index">
                <i class="bi bi-patch-question me-2"></i>Bài kiểm tra
            </a>
        </li>

        <div class="nav-section">Thực tập</div>
        <li class="nav-item">
            <a class="nav-link @(area == "Intern" && ctrl == "Task" ? "active" : "")" asp-area="Intern"
                   asp-controller="Task" asp-action="Index">
                <i class="bi bi-kanban me-2"></i>Kanban Board
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(area == "Intern" && ctrl == "DailyReport" ? "active" : "")" asp-area="Intern"
                   asp-controller="DailyReport" asp-action="Index">
                <i class="bi bi-journal-text me-2"></i>Daily Report
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(area == "Intern" && ctrl == "Timesheet" ? "active" : "")" asp-area="Intern"
                   asp-controller="Timesheet" asp-action="Index">
                <i class="bi bi-clock me-2"></i>Timesheet
            </a>
        </li>
    }
</ul>
