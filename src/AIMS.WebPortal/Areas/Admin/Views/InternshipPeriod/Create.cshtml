@model CreateInternshipPeriodRequest

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-1">Tạo kỳ thực tập</h3>
        <div class="text-muted">Thiết lập tên kỳ và khoảng thời gian ngay từ đầu.</div>
    </div>
    <a class="btn btn-outline-primary" asp-action="Index">
        <i class="bi bi-arrow-left me-2"></i>Quay lại
    </a>
</div>

<div class="card">
    <div class="card-body">
        <form method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="col-12">
                <label asp-for="Name" class="form-label fw-semibold"></label>
                <input asp-for="Name" class="form-control" placeholder="Ví dụ: Kỳ Hè 2026" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="StartDate" class="form-label fw-semibold"></label>
                <input asp-for="StartDate" class="form-control" type="date" />
            </div>
            <div class="col-md-6">
                <label asp-for="EndDate" class="form-label fw-semibold"></label>
                <input asp-for="EndDate" class="form-control" type="date" />
            </div>
            <div class="col-12 d-flex justify-content-end gap-2 mt-3">
                <a class="btn btn-outline-primary" asp-action="Index">Hủy</a>
                <button class="btn btn-primary" type="submit">
                    <i class="bi bi-save me-2"></i>Tạo kỳ thực tập
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
