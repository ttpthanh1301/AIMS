@model List<InternshipPeriodVm>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h3 class="fw-bold mb-1">Kỳ thực tập</h3>
    </div>
    <a class="btn btn-primary" asp-action="Create">
        <i class="bi bi-calendar-plus me-2"></i>Tạo kỳ mới
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="row g-4">
@if (Model.Count == 0)
{
    <div class="col-12">
        <div class="card">
            <div class="card-body text-center text-muted py-5">Chưa có kỳ thực tập nào.</div>
        </div>
    </div>
}
else
{
    @foreach (var period in Model)
    {
        <div class="col-xl-4 col-md-6">
            <div class="card h-100">
                <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h5 class="fw-bold mb-1">@period.Name</h5>
                            <div class="small text-muted">
                                @period.StartDate.ToString("dd/MM/yyyy") - @period.EndDate.ToString("dd/MM/yyyy")
                            </div>
                        </div>
                        <span class="badge @(period.IsActive ? "bg-success" : "bg-secondary") rounded-pill">
                            @(period.IsActive ? "Đang hoạt động" : "Đã đóng")
                        </span>
                    </div>
                    <div class="small text-muted mb-4">Số intern trong kỳ: @period.TotalInterns</div>
                    <div class="mt-auto d-flex flex-wrap gap-2">
                        <a class="btn btn-outline-primary btn-sm"
                           asp-action="Edit" asp-route-id="@period.Id">
                            <i class="bi bi-pencil-square me-1"></i>Sửa
                        </a>
                        @if (!period.IsActive)
                        {
                            <form asp-action="Activate" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@period.Id" />
                                <button class="btn btn-primary btn-sm" type="submit">
                                    <i class="bi bi-lightning-charge me-1"></i>Kích hoạt
                                </button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="Close" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@period.Id" />
                                <button class="btn btn-outline-danger btn-sm" type="submit">
                                    <i class="bi bi-x-circle me-1"></i>Đóng kỳ
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
}
</div>
