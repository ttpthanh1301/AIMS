@using AIMS.ViewModels.LMS
@model QuizAttemptVm
@{
    ViewData["Title"] = "Làm bài kiểm tra";
    var attempt = Model;
}

@section Styles {
<link rel="stylesheet" href="~/css/intern-quiz-take.css" />
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">
        <i class="bi bi-pencil-square text-primary me-2"></i>Bài kiểm tra
    </h5>
    <div class="card border-0 shadow-sm px-4 py-2">
        <div class="text-center">
            <small class="text-muted d-block">Thời gian còn lại</small>
            <span id="timer" class="fs-4 fw-bold text-danger">
                @(attempt.TimeLimit != null ? $"{attempt.TimeLimit}:00" : "∞")
            </span>
        </div>
    </div>
</div>

<form asp-action="Submit" method="post" id="quizForm">
    <input type="hidden" name="attemptId" value="@attempt.AttemptId" />

    @{ int qNum = 1; }
    @foreach (var q in attempt.Questions)
    {
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <div class="fw-semibold mb-3">
                    <span class="badge bg-primary me-2">@qNum</span>
                    @q.QuestionText
                    <small class="text-muted ms-2">(@q.Score điểm)</small>
                </div>
                <div class="ps-3">
                    @foreach (var opt in q.Options)
                    {
                        <div class="form-check mb-2">
                            <input type="radio"
                                   class="form-check-input"
                                   name="q_@q.Id"
                                   value="@opt.Id"
                                   id="opt_@opt.Id"
                                   required />
                            <label class="form-check-label"
                                   for="opt_@opt.Id"
                                   class="quiz-option-label">
                                @opt.OptionText
                            </label>
                        </div>
                    }
                </div>
            </div>
        </div>
        qNum++;
    }

    <div class="d-flex justify-content-between mt-4">
        <span class="text-muted">Tổng: @attempt.TotalQuestions câu</span>
        <button type="submit" class="btn btn-success px-5"
                onclick="return confirm('Bạn chắc chắn muốn nộp bài?')">
            <i class="bi bi-send me-1"></i>Nộp bài
        </button>
    </div>
</form>

@section Scripts {
<script>
@if (Model.TimeLimit != null)
{
    @:let totalSeconds = @Model.TimeLimit * 60;
    @:const timerEl = document.getElementById('timer');
    @:const form    = document.getElementById('quizForm');
    @:const interval = setInterval(() => {
    @:    totalSeconds--;
    @:    const m = Math.floor(totalSeconds / 60).toString().padStart(2,'0');
    @:    const s = (totalSeconds % 60).toString().padStart(2,'0');
    @:    timerEl.textContent = `${m}:${s}`;
    @:    if (totalSeconds <= 0) { clearInterval(interval); form.submit(); }
    @:}, 1000);
}
</script>
}
