@using AIMS.ViewModels.LMS
@model List<QuizBankVm>
@{
    ViewData["Title"] = "Bài kiểm tra";
    var quizzes = Model ?? new List<QuizBankVm>();
}

<h5 class="fw-bold mb-4">
    <i class="bi bi-patch-question text-primary me-2"></i>Bài kiểm tra
</h5>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="row g-3">
    @foreach (var q in quizzes)
    {
        <div class="col-md-6 col-xl-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h6 class="fw-bold">@q.Title</h6>
                    <div class="text-muted small mb-3">@q.CourseTitle</div>
                    <div class="row g-2 text-center mb-3">
                        <div class="col-4">
                            <div class="bg-light rounded p-2">
                                <div class="fw-bold text-primary">@q.TotalQuestions</div>
                                <small class="text-muted">Câu hỏi</small>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="bg-light rounded p-2">
                                <div class="fw-bold text-success">@q.PassScore%</div>
                                <small class="text-muted">Pass</small>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="bg-light rounded p-2">
                                <div class="fw-bold text-warning">@q.MaxAttempts</div>
                                <small class="text-muted">Lần thi</small>
                            </div>
                        </div>
                    </div>
                    <form asp-action="Start" method="post">
                        <input type="hidden" name="quizBankId" value="@q.Id" />
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-play-fill me-1"></i>Bắt đầu thi
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>