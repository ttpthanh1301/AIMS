@using AIMS.ViewModels.TaskManagement
@model List<TaskVm>
@{
    ViewData["Title"] = "Tasks của tôi";
    var tasks = Model ?? new List<TaskVm>();
}

<h5 class="fw-bold mb-4">
    <i class="bi bi-list-task text-primary me-2"></i>Tasks của tôi
</h5>

<div class="row g-3">
    @foreach (var task in tasks.OrderBy(t => t.Deadline))
    {
        bool isDone = task.Status == "DONE";
        bool isOverdue = task.IsOverdue;

        <div class="col-md-6 col-xl-4">
            <div class="card border-0 shadow-sm
                @(isOverdue ? "border-start border-danger border-3" :
                                   isDone ? "border-start border-success border-3" : "")">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <span class="fw-semibold">@task.Title</span>
                        <span
                            class="badge @(task.Priority == "HIGH" ? "bg-danger" : task.Priority == "MEDIUM" ? "bg-warning text-dark" : "bg-info")">
                            @task.Priority
                        </span>
                    </div>
                    <div class="text-muted small mt-1">@task.Description</div>
                    <div class="mt-2 d-flex justify-content-between align-items-center">
                        <span
                            class="badge @(isDone ? "bg-success" : isOverdue ? "bg-danger" : task.Status == "IN_PROGRESS" ? "bg-primary" : "bg-secondary")">
                            @task.Status
                        </span>
                        <small class="text-muted">
                            <i class="bi bi-calendar me-1"></i>
                            @task.Deadline.ToString("dd/MM/yyyy")
                        </small>
                    </div>
                    @if (!isDone)
                    {
                        <div class="mt-3 d-flex gap-2">
                            @if (task.Status == "TODO")
                            {
                                <form asp-action="UpdateStatus" method="post">
                                    <input type="hidden" name="id" value="@task.Id" />
                                    <input type="hidden" name="status" value="IN_PROGRESS" />
                                    <button class="btn btn-sm btn-outline-primary">
                                        ▶ Bắt đầu
                                    </button>
                                </form>
                            }
                            @if (task.Status == "IN_PROGRESS")
                            {
                                <form asp-action="UpdateStatus" method="post">
                                    <input type="hidden" name="id" value="@task.Id" />
                                    <input type="hidden" name="status" value="DONE" />
                                    <button class="btn btn-sm btn-success">
                                        ✓ Hoàn thành
                                    </button>
                                </form>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>