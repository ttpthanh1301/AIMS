@using AIMS.ViewModels.TaskManagement
@model List<DailyReportVm>
@{
    ViewData["Title"] = "Daily Reports";
    var reports = Model ?? new List<DailyReportVm>();
}

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold border-0 pt-3">
                <i class="bi bi-journal-plus text-primary me-2"></i>Nộp báo cáo hôm nay
            </div>
            <div class="card-body">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success py-2">@TempData["Success"]</div>
                }
                <form asp-action="Create" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Hôm nay đã làm gì? <span
                            class="text-danger">*</span></label>
                            <textarea name="content" class="form-control" rows="4" required
                                      placeholder="Mô tả công việc đã thực hiện..."></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Kế hoạch ngày mai</label>
                            <textarea name="plannedTomorrow" class="form-control" rows="2"
                                      placeholder="Dự kiến sẽ làm gì ngày mai..."></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Vấn đề gặp phải</label>
                            <textarea name="issues" class="form-control" rows="2"
                                      placeholder="Khó khăn, câu hỏi cần hỏi Mentor..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-send me-1"></i>Nộp báo cáo
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <h6 class="fw-bold mb-3">Lịch sử báo cáo</h6>
            @foreach (var r in reports)
            {
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="fw-semibold">
                                📅 @r.ReportDate.ToString("dd/MM/yyyy")
                            </span>
                            <span class="badge @(r.HasFeedback ? "bg-success" : "bg-secondary") rounded-pill">
                                @(r.HasFeedback ? "Có phản hồi" : "Chờ phản hồi")
                            </span>
                        </div>
                        <p class="mb-2 text-dark">@r.Content</p>
                        @if (r.MentorFeedback != null)
                        {
                            <div class="alert alert-success py-2 mb-0">
                                <strong>💬 Mentor:</strong> @r.MentorFeedback
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>