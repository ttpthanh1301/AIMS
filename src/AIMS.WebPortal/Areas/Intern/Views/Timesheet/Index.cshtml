@using AIMS.ViewModels.TaskManagement
@model TimesheetResultVm
@{
    ViewData["Title"] = "Timesheet";
    var tasks = ViewBag.Tasks as List<TaskVm> ?? new List<TaskVm>();
}

<div class="row g-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold border-0 pt-3">
                <i class="bi bi-clock-history text-primary me-2"></i>Log giờ làm
            </div>
            <div class="card-body">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success py-2">@TempData["Success"]</div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger py-2">@TempData["Error"]</div>
                }
                <form asp-action="Log" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Task</label>
                        <select name="taskId" class="form-select" required>
                            <option value="">-- Chọn task --</option>
                            @foreach (var t in tasks.Where(t =>
                                t.Status == "IN_PROGRESS" || t.Status == "TODO"))
                            {
                                <option value="@t.Id">@t.Title</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Số giờ làm</label>
                        <input name="hoursWorked" type="number"
                               step="0.5" min="0.5" max="12"
                               class="form-control" required />
                        <small class="text-muted">Tối đa 12h/ngày</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Ghi chú</label>
                        <textarea name="workNote" class="form-control" rows="2"
                                  placeholder="Mô tả công việc đã làm..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-clock me-1"></i>Log giờ
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        @if (Model != null)
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-3 bg-primary bg-opacity-10 p-3">
                        <i class="bi bi-clock text-primary fs-3"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Tổng giờ đã log</div>
                        <div class="fs-3 fw-bold text-primary">@Model.TotalHours h</div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Ngày</th><th>Task</th>
                                <th>Giờ làm</th><th>Ghi chú</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ts in Model.Items)
                            {
                                <tr>
                                    <td>@ts.WorkDate.ToString("dd/MM/yyyy")</td>
                                    <td class="fw-semibold small">@ts.TaskTitle</td>
                                    <td>
                                        <span class="badge bg-primary">@ts.HoursWorked h</span>
                                    </td>
                                    <td class="text-muted small">@ts.WorkNote</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>