@using AIMS.ViewModels.LMS
@model CourseVm

@{
    ViewData["Title"] = "Học bài";
    var course     = Model;

    // ⭐ Typed — không dùng dynamic
    var enrollment = ViewBag.Enrollment as EnrollmentVm;
}

<div class="row g-4">
    <!-- Video Player -->
    <div class="col-md-8">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body p-0">
                <div id="contentArea" class="p-4 text-center text-muted"
                     style="min-height:300px;display:flex;align-items:center;justify-content:center">
                    <div>
                        <i class="bi bi-play-circle fs-1 text-primary"></i>
                        <p class="mt-2">Chọn bài học từ danh sách bên phải</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Nút hoàn thành (inject bằng JS) -->
        <div id="completeArea"></div>

        <!-- Progress overall -->
        @if (enrollment != null)
        {
            <div class="card border-0 shadow-sm mt-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="fw-semibold">Tiến độ khóa học</span>
                        <span class="text-primary fw-bold">@enrollment.CompletionPercent%</span>
                    </div>
                    <div class="progress" style="height:10px">
                        <div class="progress-bar bg-primary"
                             style="width:@enrollment.CompletionPercent%"></div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Danh sách bài học -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold border-0 pt-3">
                <i class="bi bi-list-ul me-2"></i>@course?.Title
            </div>
            <div class="card-body p-0" style="max-height:500px;overflow-y:auto">
                @if (course?.Chapters != null)
                {
                    foreach (var chapter in course.Chapters)
                    {
                        <div class="p-2 bg-light border-bottom">
                            <small class="fw-semibold text-muted">@chapter.Title</small>
                        </div>
                        foreach (var lesson in chapter.Lessons)
                        {
                            <div class="d-flex align-items-center p-3 border-bottom"
                                 style="cursor:pointer"
                                 onclick="loadLesson(
                                     '@lesson.ContentUrl',
                                     '@lesson.LessonType',
                                     '@lesson.Title',
                                     @lesson.Id,
                                     @(enrollment?.Id ?? 0),
                                     @(course.Id))">
                                <i class="bi @(lesson.LessonType=="VIDEO"?"bi-play-circle text-primary":"bi-file-text text-danger") me-2"></i>
                                <div class="flex-grow-1">
                                    <div class="small fw-semibold">@lesson.Title</div>
                                    <small class="text-muted">@lesson.DurationMinutes phút</small>
                                </div>
                            </div>
                        }
                    }
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function loadLesson(url, type, title, lessonId, enrollmentId, courseId) {
    const area = document.getElementById('contentArea');

    if (type === 'VIDEO' && url) {
        const ytMatch = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&]+)/);
        if (ytMatch) {
            area.innerHTML = `<iframe width="100%" height="360"
                src="https://www.youtube.com/embed/${ytMatch[1]}"
                frameborder="0" allowfullscreen></iframe>`;
        } else {
            area.innerHTML = `<video controls style="width:100%;max-height:360px">
                <source src="${url}"></video>`;
        }
    } else if (type === 'DOCUMENT' && url) {
        area.innerHTML = `<div style="padding:2rem">
            <i class="bi bi-file-pdf fs-1 text-danger"></i>
            <p class="mt-2 fw-semibold">${title}</p>
            <a href="${url}" target="_blank" class="btn btn-outline-primary">
                <i class="bi bi-download me-1"></i>Tải tài liệu
            </a></div>`;
    } else {
        area.innerHTML = `<p class="p-4">${title}</p>`;
    }

    // Nút đánh dấu hoàn thành
    const completeArea = document.getElementById('completeArea');
    completeArea.innerHTML = `
        <div class="mt-3 text-end">
            <form method="post" action="/Intern/LMS/CompleteLesson">
                <input type="hidden" name="enrollmentId" value="${enrollmentId}" />
                <input type="hidden" name="lessonId"     value="${lessonId}" />
                <input type="hidden" name="courseId"     value="${courseId}" />
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-check-lg me-1"></i>Đánh dấu hoàn thành
                </button>
            </form>
        </div>`;
}
</script>
}