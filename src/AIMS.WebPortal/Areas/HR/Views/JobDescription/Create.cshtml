@model AIMS.ViewModels.Recruitment.JobDescriptionFormVm
@using AIMS.ViewModels.Recruitment

@{
    ViewData["Title"] = "Tạo Job Description";
    var positions = ViewBag.Positions as IEnumerable<JobPositionVm> ?? Enumerable.Empty<JobPositionVm>();
    var error = ViewData["Error"] as string;
}

@section Styles {
<link rel="stylesheet" href="~/css/hr-job-description-create.css" />
}

<div class="card border-0 shadow-sm job-description-create-card">
    <div class="card-header bg-white fw-semibold border-0 pt-3">
        <i class="bi bi-plus-circle text-primary me-2"></i>Tạo JD mới
    </div>

    <div class="card-body">
        @if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="alert alert-danger">@error</div>
        }

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="JobPositionId" class="form-label fw-semibold">Vị trí tuyển dụng có sẵn</label>
                <select asp-for="JobPositionId" class="form-select">
                    <option value="">-- Chọn vị trí --</option>
                    @foreach (var p in positions)
                    {
                        <option value="@p.Id">@p.Title</option>
                    }
                </select>
                <small class="text-muted">Có thể chọn sẵn hoặc tạo vị trí mới ở phần bên dưới.</small>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="NewJobPositionTitle" class="form-label fw-semibold">Tạo vị trí mới</label>
                    <input asp-for="NewJobPositionTitle"
                           class="form-control"
                           placeholder="VD: Data Engineer Intern" />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="NewJobPositionDescription" class="form-label fw-semibold">Mô tả vị trí mới</label>
                    <input asp-for="NewJobPositionDescription"
                           class="form-control"
                           placeholder="VD: Python, ETL, SQL" />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label fw-semibold">Tiêu đề JD</label>
                <input asp-for="Title"
                       class="form-control"
                       placeholder="VD: Junior .NET Developer - Kỳ Hè 2025"
                       required />
            </div>

            <div class="mb-3">
                <label asp-for="DetailContent" class="form-label fw-semibold">Mô tả chi tiết</label>
                <textarea asp-for="DetailContent"
                          class="form-control"
                          rows="4"
                          required></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="RequiredSkills" class="form-label fw-semibold">
                    Required Skills
                    <small class="text-danger">(AI dùng để so khớp CV)</small>
                </label>

                <textarea asp-for="RequiredSkills"
                          class="form-control"
                          rows="4"
                          placeholder="C#&#10;.NET&#10;ASP.NET Core&#10;EF Core&#10;SQL Server"
                          required></textarea>

                <small class="text-muted">Mỗi dòng hoặc mỗi cụm keyword sẽ được dùng để đối chiếu CV.</small>
            </div>

            <div class="mb-3">
                <label asp-for="MinGPA" class="form-label fw-semibold">GPA tối thiểu</label>
                <input asp-for="MinGPA"
                       type="number"
                       step="0.1"
                       min="0"
                       max="4"
                       class="form-control"
                       placeholder="3.0" />
                <small class="text-muted">Tạm thời bỏ deadline tuyển dụng khỏi JD.</small>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Tạo JD
                </button>

                <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
            </div>
        </form>
    </div>
</div>
