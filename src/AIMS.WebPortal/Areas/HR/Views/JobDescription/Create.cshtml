@{
    ViewData["Title"] = "Tạo Job Description";
    var positions = ViewBag.Positions as List<dynamic> ?? new();
}

<div class="card border-0 shadow-sm" style="max-width:700px">
    <div class="card-header bg-white fw-semibold border-0 pt-3">
        <i class="bi bi-plus-circle text-primary me-2"></i>Tạo JD mới
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label class="form-label fw-semibold">Vị trí tuyển dụng</label>
                <select name="jobPositionId" class="form-select" required>
                    <option value="">-- Chọn vị trí --</option>
                    @foreach (var p in positions)
                    {
                        <option value="@p.id">@p.title</option>
                    }
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Tiêu đề JD</label>
                <input name="title" class="form-control"              placeholder="VD: Junior .NET Developer - Kỳ Hè 2025"
                       required />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Mô tả chi tiết</label>
                <textarea name="detailContent" class="form-control"                rows="4" required></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Required Skills
                    <small class="text-danger">(AI dùng để so khớp CV)</small>
                </label>
                <input name="requiredSkills" class="form-control"                 placeholder="C# .NET ASP.NET EF Core SQL Docker JWT"
                       required />
                <small class="text-muted">Nhập các keyword cách nhau bằng dấu cách</small>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-semibold">GPA tối thiểu</label>
                    <input name="minGPA" type="number" step="0.1"                    min="0" max="4" class="form-control"
                           placeholder="3.0" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-semibold">Deadline</label>
                    <input name="deadlineDate" type="date" class="form-control" />
                </div>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Tạo JD
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
            </div>
        </form>
    </div>
</div>