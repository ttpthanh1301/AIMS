@model AIMS.ViewModels.Recruitment.JobDescriptionFormVm
@using AIMS.ViewModels.Recruitment

@{
    ViewData["Title"] = "Chỉnh sửa Job Description";
    var positions = ViewBag.Positions as IEnumerable<JobPositionVm> ?? Enumerable.Empty<JobPositionVm>();
    var error = ViewData["Error"] as string;
}

@section Styles {
<link rel="stylesheet" href="~/css/hr-job-description-create.css" />
}

<div class="card border-0 shadow-sm job-description-create-card">
    <div class="card-header bg-white fw-semibold border-0 pt-3">
        <i class="bi bi-pencil-square text-warning me-2"></i>Chỉnh sửa JD #@Model.Id
    </div>

    <div class="card-body">
        @if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="alert alert-danger">@error</div>
        }

        <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="JobPositionId" class="form-label fw-semibold">Vị trí tuyển dụng có sẵn</label>
                <select asp-for="JobPositionId" class="form-select">
                    <option value="">-- Chọn vị trí --</option>
                    @foreach (var p in positions)
                    {
                        <option value="@p.Id">@p.Title</option>
                    }
                </select>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="NewJobPositionTitle" class="form-label fw-semibold">Đổi sang vị trí mới</label>
                    <input asp-for="NewJobPositionTitle"
                           class="form-control"
                           placeholder="Để trống nếu giữ/chọn vị trí hiện có" />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="NewJobPositionDescription" class="form-label fw-semibold">Mô tả vị trí mới</label>
                    <input asp-for="NewJobPositionDescription"
                           class="form-control"
                           placeholder="VD: Java, Spring Boot, PostgreSQL" />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label fw-semibold">Tiêu đề JD</label>
                <input asp-for="Title" class="form-control" required />
            </div>

            <div class="mb-3">
                <label asp-for="DetailContent" class="form-label fw-semibold">Mô tả chi tiết</label>
                <textarea asp-for="DetailContent" class="form-control" rows="4" required></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="RequiredSkills" class="form-label fw-semibold">Required Skills</label>
                <textarea asp-for="RequiredSkills" class="form-control" rows="4" required></textarea>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="MinGPA" class="form-label fw-semibold">GPA tối thiểu</label>
                    <input asp-for="MinGPA" type="number" step="0.1" min="0" max="4" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Status" class="form-label fw-semibold">Trạng thái</label>
                    <select asp-for="Status" class="form-select">
                        <option value="OPEN">OPEN</option>
                        <option value="CLOSED">CLOSED</option>
                    </select>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning text-dark">
                    <i class="bi bi-save me-1"></i>Lưu thay đổi
                </button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Hủy</a>
            </div>
        </form>
    </div>
</div>
