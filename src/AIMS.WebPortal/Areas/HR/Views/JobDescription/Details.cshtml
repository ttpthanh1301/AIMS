@model AIMS.ViewModels.Recruitment.JobDescriptionVm

@{
    ViewData["Title"] = "Chi tiết Job Description";
    var error = ViewData["Error"] as string;
}

<div class="d-flex justify-content-between align-items-start gap-3 mb-4 flex-wrap">
    <div>
        <h4 class="fw-bold mb-1">@Model.Title</h4>
        <div class="text-muted">JD #@Model.Id • @Model.JobPositionTitle</div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning text-dark">
            <i class="bi bi-pencil me-1"></i>Chỉnh sửa
        </a>
        <form asp-action="Delete"
              asp-route-id="@Model.Id"
              method="post"
              class="d-inline"
              onsubmit="return confirm('Xóa JD này?');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-danger">
                <i class="bi bi-trash me-1"></i>Xóa
            </button>
        </form>
        <a asp-area="HR"
           asp-controller="Screening"
           asp-action="Ranking"
           asp-route-jdId="@Model.Id"
           class="btn btn-outline-primary">
            <i class="bi bi-trophy me-1"></i>Ranking
        </a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <div class="row g-4">
            <div class="col-md-6">
                <div class="small text-muted mb-1">Vị trí tuyển dụng</div>
                <div class="fw-semibold">@Model.JobPositionTitle</div>
            </div>
            <div class="col-md-3">
                <div class="small text-muted mb-1">Trạng thái</div>
                <span class="badge @(Model.Status == "OPEN" ? "bg-success" : "bg-secondary")">@Model.Status</span>
            </div>
            <div class="col-md-6">
                <div class="small text-muted mb-1">GPA tối thiểu</div>
                <div class="fw-semibold">@(Model.MinGPA?.ToString("0.0") ?? "-")</div>
            </div>
            <div class="col-md-6">
                <div class="small text-muted mb-1">Ngày tạo</div>
                <div class="fw-semibold">@Model.CreateDate.ToString("yyyy-MM-dd HH:mm")</div>
            </div>
            <div class="col-12">
                <div class="small text-muted mb-1">Người tạo</div>
                <div class="fw-semibold">@Model.CreatedByUser</div>
            </div>
            <div class="col-12">
                <div class="small text-muted mb-1">Mô tả chi tiết</div>
                <div class="border rounded p-3 bg-light-subtle" style="white-space: pre-wrap;">@Model.DetailContent</div>
            </div>
            <div class="col-12">
                <div class="small text-muted mb-1">Required Skills</div>
                <div class="border rounded p-3 bg-light-subtle" style="white-space: pre-wrap;">@Model.RequiredSkills</div>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">Quay lại danh sách</a>
</div>
