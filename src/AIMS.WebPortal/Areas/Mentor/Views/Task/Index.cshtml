@model List<AIMS.ViewModels.TaskManagement.TaskListVm>
@{
    ViewData["Title"] = "Kanban Board";
    var assignments = ViewBag.Assignments
        as List<AIMS.ViewModels.TaskManagement.AssignmentListVm>
        ?? new();

    // ⭐ PascalCase vì typed ViewModel
    var todo       = Model.Where(t => t.Status == "TODO").ToList();
    var inProgress = Model.Where(t => t.Status == "IN_PROGRESS").ToList();
    var done       = Model.Where(t => t.Status == "DONE").ToList();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">
        <i class="bi bi-kanban text-primary me-2"></i>Kanban Board
    </h5>
    <button class="btn btn-primary"
            data-bs-toggle="modal"
            data-bs-target="#createTaskModal">
        <i class="bi bi-plus-lg me-1"></i>Giao task
    </button>
</div>

<div class="row g-3">
    @{
        var columns = new[]
        {
            ("TODO",        "secondary", todo,       "TODO"),
            ("IN PROGRESS", "primary",   inProgress, "IN_PROGRESS"),
            ("DONE",        "success",   done,       "DONE"),
        };
    }

    @foreach (var (colTitle, colColor, colTasks, colStatus) in columns)
    {
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-@colColor text-white fw-semibold">
                    @colTitle
                    <span class="badge bg-white text-@colColor ms-2">
                        @colTasks.Count
                    </span>
                </div>
                <div class="card-body p-2" style="min-height:300px">
                    @foreach (var task in colTasks)
                    {
                        <div class="card mb-2 border-0 shadow-sm task-card"
                             data-id="@task.Id"
                             data-status="@task.Status">
                            <div class="card-body p-3">
                                <div class="fw-semibold mb-1">@task.Title</div>
                                <div class="d-flex gap-1 mb-2">
                                    <span class="badge rounded-pill @(task.Priority == "HIGH" ? "bg-danger" : task.Priority == "MEDIUM" ? "bg-warning text-dark" : "bg-info")"
                                          style="font-size:.7rem">
                                        @task.Priority
                                    </span>
                                    @if (task.IsOverdue)
                                    {
                                        <span class="badge bg-danger rounded-pill"
                                              style="font-size:.7rem">OVERDUE</span>
                                    }
                                </div>
                                <div class="text-muted" style="font-size:.78rem">
                                    <i class="bi bi-person me-1"></i>@task.InternName
                                </div>
                                <div class="text-muted" style="font-size:.78rem">
                                    <i class="bi bi-calendar me-1"></i>
                                    @task.Deadline.ToString("dd/MM/yyyy")
                                </div>
                                <div class="mt-2 d-flex gap-1">
                                    @if (task.Status != "TODO")
                                    {
                                        <button class="btn btn-sm btn-outline-secondary"
                                                onclick="moveTask(@task.Id, 'prev')">
                                            ◀
                                        </button>
                                    }
                                    @if (task.Status != "DONE")
                                    {
                                        <button class="btn btn-sm btn-outline-primary ms-auto"
                                                onclick="moveTask(@task.Id, 'next')">
                                            ▶
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

<!-- Modal tạo task -->
<div class="modal fade" id="createTaskModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Giao task mới</h5>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Intern</label>
                        <select name="assignmentId" class="form-select" required>
                            @foreach (var a in assignments)
                            {
                                <option value="@a.Id">@a.InternName</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tiêu đề task</label>
                        <input name="title" class="form-control" required />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Priority</label>
                            <select name="priority" class="form-select">
                                <option value="LOW">Low</option>
                                <option value="MEDIUM" selected>Medium</option>
                                <option value="HIGH">High</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Deadline</label>
                            <input name="deadline" type="date"
                                   class="form-control" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Giờ ước tính</label>
                        <input name="estimatedHours" type="number"
                               step="0.5" class="form-control" placeholder="8" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary"
                            data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Tạo task</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
const statusFlow = ['TODO', 'IN_PROGRESS', 'DONE'];

async function moveTask(id, direction) {
    const card    = document.querySelector(`.task-card[data-id="${id}"]`);
    const current = card.dataset.status;
    const idx     = statusFlow.indexOf(current);
    const next    = direction === 'next'
        ? statusFlow[idx + 1]
        : statusFlow[idx - 1];

    if (!next) return;

    const token = document.querySelector('[name=__RequestVerificationToken]')?.value ?? '';

    await fetch('/Mentor/Task/UpdateStatus', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'RequestVerificationToken': token,
        },
        body: JSON.stringify({ id, status: next }),
    });

    location.reload();
}
</script>
}