@using AIMS.ViewModels.LMS
@model List<QuizAttemptReviewListVm>
@{
    ViewData["Title"] = "Bài chờ chấm";
    var quiz = ViewBag.Quiz as QuizBankVm;
    var pendingAttempts = Model ?? new List<QuizAttemptReviewListVm>();
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h4 class="fw-bold mb-1">Bài chờ chấm</h4>
        <div class="text-muted">@quiz?.Title</div>
        @if (!string.IsNullOrWhiteSpace(quiz?.CourseTitle))
        {
            <div class="small text-muted">Khóa học: @quiz.CourseTitle</div>
        }
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Quay lại Quiz
    </a>
</div>

@if (pendingAttempts.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Học viên</th>
                        <th>Lần thi</th>
                        <th>Thời gian nộp</th>
                        <th>Câu chờ chấm</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in pendingAttempts)
                {
                    <tr>
                        <td class="fw-semibold">@item.InternName</td>
                        <td>#@item.AttemptNumber</td>
                        <td>@item.SubmittedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <span class="badge bg-warning text-dark">@item.PendingCount câu</span>
                        </td>
                        <td class="text-end">
                            <a asp-action="ReviewAttempt" asp-route-attemptId="@item.AttemptId"
                               class="btn btn-sm btn-warning">
                                <i class="bi bi-pencil-square me-1"></i>Chấm bài
                            </a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body py-5 text-center">
            <div class="mb-3 text-success fs-1">
                <i class="bi bi-check2-circle"></i>
            </div>
            <h5 class="fw-bold">Không còn bài chờ chấm</h5>
            <p class="text-muted mb-0">Mọi câu tự luận của quiz này đã được mentor chấm xong.</p>
        </div>
    </div>
}
